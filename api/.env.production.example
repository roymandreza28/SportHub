# Production template for the Railway "web" and "reverb" services. Copy the
# values that apply into each service's Railway "Variables" tab — do not
# commit a real .env with secrets. Both services should share the same
# APP_KEY, DB_*, and REVERB_* values so sessions/broadcasts stay consistent
# between them.

APP_NAME=Sporthub
APP_ENV=production
# Generate once with `php artisan key:generate --show` and paste the same
# value into both the web and reverb services — do not regenerate per service.
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.sporthub.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# Railway's Postgres plugin exposes these as reference variables you can wire
# up directly in the dashboard instead of copying literal values, e.g.
# DB_HOST=${{Postgres.PGHOST}}, DB_PORT=${{Postgres.PGPORT}},
# DB_DATABASE=${{Postgres.PGDATABASE}}, DB_USERNAME=${{Postgres.PGUSER}},
# DB_PASSWORD=${{Postgres.PGPASSWORD}}
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Requires custom domains on both sides (see docs/DEPLOYMENT.md) — cookies
# cannot be shared between unrelated third-party domains like *.vercel.app
# and *.railway.app.
SESSION_DOMAIN=.sporthub.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=app.sporthub.com
CORS_ALLOWED_ORIGINS=https://app.sporthub.com
FRONTEND_URL=https://app.sporthub.com

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

MAIL_MAILER=log

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.sporthub.com
REVERB_PORT=443
REVERB_SCHEME=https
